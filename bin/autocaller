#!/usr/bin/env bash
# autocaller — thin wrapper around `python -m app.cli`.
# Resolves the project root relative to this script, activates the venv if
# one exists, and forwards args.

set -euo pipefail
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd -- "${SCRIPT_DIR}/.." && pwd)"

# Load .env if present
if [[ -f "${PROJECT_ROOT}/.env" ]]; then
    set -a
    # shellcheck disable=SC1091
    source "${PROJECT_ROOT}/.env"
    set +a
fi

# Prefer venv python if available
if [[ -x "${PROJECT_ROOT}/.venv/bin/python" ]]; then
    PY="${PROJECT_ROOT}/.venv/bin/python"
else
    PY="${PYTHON:-python3}"
fi

cd "${PROJECT_ROOT}"
exec "${PY}" -m app.cli "$@"
