# Attorney cold-call autocaller — .env template.
# Copy to .env, then `bin/autocaller config init` can walk you through most of it.

# ---- Backend ----
BACKEND_PORT=8000
DATABASE_URL=postgresql://autocaller:password@localhost:5432/autocaller

# ---- OpenAI Realtime (required) ----
OPENAI_API_KEY=sk-your-key-here
# Optional overrides
# OPENAI_REALTIME_MODEL=gpt-realtime-2025-08-28
# OPENAI_VOICE=alloy
# OPENAI_VAD_THRESHOLD=0.85
# OPENAI_VAD_PREFIX_MS=300
# OPENAI_VAD_SILENCE_MS=700

# ---- Twilio (required for real outbound calls) ----
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+15551234567
# Must be set to "true" before any real call goes out — safety gate.
ALLOW_TWILIO_CALLS=false
# Public HTTPS URL where Twilio can reach your backend for TwiML + media-stream WS.
PUBLIC_BASE_URL=https://autocaller.example.com

# ---- Cal.com (required for demo booking) ----
CALCOM_API_KEY=cal_...
CALCOM_EVENT_TYPE_ID=123456
CALCOM_DEFAULT_TIMEZONE=America/New_York
# Optional
# CALCOM_API_BASE=https://api.cal.com/v2
# CALCOM_API_VERSION=2024-08-13

# ---- Sales rep context (injected into the AI prompt) ----
SALES_REP_NAME=Alex
SALES_REP_COMPANY=Acme AI Labs
SALES_REP_EMAIL=alex@acme.ai
PRODUCT_CONTEXT="We've shipped intake bots, demand letter tools, and lien-processing automations for 8+ PI firms — average 11 hrs/week saved."

# ---- Calling hours (lead's local timezone) ----
# Not consumed from env directly; configured in DB via `autocaller config` or settings API.
# BUSINESS_HOURS_START=09:00
# BUSINESS_HOURS_END=17:00
# BUSINESS_HOURS_DAYS=0,1,2,3,4

# ---- Optional: daily Slack report ----
# SLACK_DAILY_REPORT_ENABLED=false
# SLACK_DAILY_REPORT_WEBHOOK_URL=https://hooks.slack.com/services/...
# SLACK_DAILY_REPORT_HOUR=7
# SLACK_DAILY_REPORT_TIMEZONE=America/Los_Angeles

# ---- Optional: follow-up email SMTP ----
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USERNAME=apikey
# SMTP_PASSWORD=...
# SMTP_FROM_EMAIL=noreply@acme.ai

# ---- Optional: verbose logs ----
# VERBOSE_LOGGING=true
